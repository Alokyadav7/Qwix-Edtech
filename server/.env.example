# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# MongoDB and Redis
MONGODB_URI=mongodb://127.0.0.1:27017/studentplatform
REDIS_URL=redis://127.0.0.1:6379

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
REFRESH_COOKIE_NAME=student_platform_refresh

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# Email
SENDGRID_API_KEY=
EMAIL_FROM=noreply@studentplatform.test

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Judge0
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional push notifications
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Puppeteer (PDF generation)
# Leave blank to use Puppeteer's bundled Chrome, or set path for Docker/CI
PUPPETEER_EXECUTABLE_PATH=
# Set to "true" to skip Chrome download during npm install (use system Chrome)
PUPPETEER_SKIP_DOWNLOAD=true
